FROM node:18-slim

# Install Ruby
RUN apt-get update && apt-get install -y \
    ruby \
    ruby-dev \
    build-essential \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install bundler
RUN gem install bundler

WORKDIR /app

# Copy and install dependencies
COPY Gemfile* ./
RUN bundle install

# Copy source
COPY . .

# Make executable
RUN chmod +x slate.sh

EXPOSE 4567

CMD ["bundle", "exec", "middleman", "serve", "--bind-address=0.0.0.0"]